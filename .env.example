# sec-13f-filings — environment variables
#
# Copy to .env (development) or .env.production (Hetzner) and fill in.
# Most are optional; the REQUIRED group is marked.

# ── REQUIRED ─────────────────────────────────────────────────────────
DATABASE_URL=postgres://13f:CHANGE_ME@localhost:5432/13f_development
SECRET_KEY_BASE=                              # bin/rails secret
RAILS_MASTER_KEY=                             # contents of config/master.key
SEC_USER_AGENT="F13 Explorer admin@example.com"   # SEC requires User-Agent for EDGAR downloads

# ── CORS ─────────────────────────────────────────────────────────────
# Default: http://localhost:5173 (Vite dev). In production set to the SPA URL.
SPA_ORIGIN=http://localhost:5173

# ── AI provider keys (all optional) ──────────────────────────────────
# Per-session keys override these; this is the system fallback used by the
# hourly GenerateInsightsJob (which has no session) and by users who haven't
# configured their own key.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
NIM_API_KEY=
# Ollama uses a per-session endpoint URL (no key)

# Default model for the background Insights job. If unset, falls back to
# claude-sonnet-4-6.
INSIGHTS_MODEL=claude-sonnet-4-6

# ── AI key encryption ────────────────────────────────────────────────
# 32-byte symmetric key used by SymmetricEncryption concern to encrypt
# AiProviderConfig#api_key. If unset, derived from SECRET_KEY_BASE via
# ActiveSupport::KeyGenerator. Set explicitly only if you want key rotation
# independent of SECRET_KEY_BASE.
AI_KEY_ENCRYPTION_KEY=

# ── CUSIP→ticker resolution ──────────────────────────────────────────
# Optional OpenFIGI API key. Without it: 6s sleep between batches (still
# works, just slow). With it: 0.5s sleep.
OPENFIGI_KEY=

# ── Production runtime tuning ────────────────────────────────────────
PORT=3000
WEB_CONCURRENCY=2          # puma workers
RAILS_MAX_THREADS=5        # threads per worker
RAILS_LOG_TO_STDOUT=true   # for systemd journalctl
RAILS_SERVE_STATIC_FILES=  # leave empty in production; Caddy serves the SPA

# ── Observability ────────────────────────────────────────────────────
SENTRY_DSN=
BUILD_SHA=
